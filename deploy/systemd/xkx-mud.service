[Unit]
Description=XKX FluffOS MUD Driver
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=xkx
Group=xkx
WorkingDirectory=/opt/xkx
Environment=LANG=en_US.UTF-8
Environment=LC_ALL=en_US.UTF-8
ExecStart=/opt/xkx/driver config.xkx
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

# MUD 只在本机监听，不对外暴露 8888
StandardOutput=journal
StandardError=journal
SyslogIdentifier=xkx-mud

[Install]
WantedBy=multi-user.target
